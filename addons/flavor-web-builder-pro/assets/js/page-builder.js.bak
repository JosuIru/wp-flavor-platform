/**
 * Flavor Page Builder - JavaScript
 */

(function($) {
    'use strict';

    const FlavorPageBuilder = {
        layout: [],
        currentEditingIndex: null,
        selectedComponentIndex: null,
        components: {},
        previewCache: {},
        previewObserver: null,
        activePreviewRequests: 0,
        maxConcurrentPreviews: 3,
        historyStack: [],
        historyPointer: -1,
        maxHistorySize: 30,

        init: function() {
            this.components = flavorPageBuilder.components || {};
            this.loadLayout();
            this.bindEvents();
            this.initSortable();
            this.initPreviewObserver();
            this.pushHistory();
        },

        loadLayout: function() {
            const layoutData = $('#flavor_page_layout').val();
            if (layoutData) {
                try {
                    this.layout = JSON.parse(layoutData);
                } catch (e) {
                    this.layout = [];
                }
            }
        },

        saveLayout: function() {
            $('#flavor_page_layout').val(JSON.stringify(this.layout));
        },

        bindEvents: function() {
            const self = this;

            // Añadir componente
            $('#flavor-pb-add-component').on('click', function() {
                self.openComponentLibrary();
            });

            // Cargar plantilla
            $('#flavor-pb-load-template').on('click', function() {
                self.openTemplateLibrary();
            });

            // Cerrar sidebar
            $('.flavor-pb-close-sidebar').on('click', function() {
                $('#flavor-pb-sidebar').fadeOut();
            });

            // Toggle acordeón de componentes
            $(document).on('click', '.flavor-pb-accordion-header', function() {
                const $header = $(this);
                const $content = $header.next('.flavor-pb-accordion-content');
                const $icon = $header.find('.flavor-pb-accordion-icon');

                if ($header.hasClass('active')) {
                    $header.removeClass('active');
                    $icon.removeClass('dashicons-arrow-up').addClass('dashicons-arrow-down');
                    $content.slideUp(300);
                } else {
                    $('.flavor-pb-accordion-header').removeClass('active');
                    $('.flavor-pb-accordion-icon').removeClass('dashicons-arrow-up').addClass('dashicons-arrow-down');
                    $('.flavor-pb-accordion-content').slideUp(300);

                    $header.addClass('active');
                    $icon.removeClass('dashicons-arrow-down').addClass('dashicons-arrow-up');
                    $content.slideDown(300);
                }
            });

            // Seleccionar componente de la librería
            $(document).on('click', '.flavor-pb-component-card', function() {
                const componentId = $(this).data('component-id');
                self.addComponent(componentId);
                $('#flavor-pb-sidebar').fadeOut();
            });

            // Click en preview overlay → seleccionar componente
            $(document).on('click', '.flavor-pb-preview-overlay', function() {
                const index = $(this).closest('.flavor-pb-component-item').data('index');
                self.selectComponent(index);
            });

            // Editar componente → seleccionar en panel lateral
            $(document).on('click', '.flavor-pb-edit-component', function() {
                const index = $(this).closest('.flavor-pb-component-item').data('index');
                self.selectComponent(index);
            });

            // Duplicar componente
            $(document).on('click', '.flavor-pb-duplicate-component', function() {
                const index = $(this).closest('.flavor-pb-component-item').data('index');
                self.duplicateComponent(index);
            });

            // Eliminar componente
            $(document).on('click', '.flavor-pb-delete-component', function() {
                if (confirm(flavorPageBuilder.i18n.confirmDelete)) {
                    const index = $(this).closest('.flavor-pb-component-item').data('index');
                    self.deleteComponent(index);
                }
            });

            // Mover arriba
            $(document).on('click', '.flavor-pb-move-up', function() {
                const index = $(this).closest('.flavor-pb-component-item').data('index');
                self.moveComponent(index, 'up');
            });

            // Mover abajo
            $(document).on('click', '.flavor-pb-move-down', function() {
                const index = $(this).closest('.flavor-pb-component-item').data('index');
                self.moveComponent(index, 'down');
            });

            // Repeater: toggle item expand/collapse
            $(document).on('click', '.flavor-pb-repeater-toggle', function(e) {
                e.preventDefault();
                const $item = $(this).closest('.flavor-pb-repeater-item');
                const $body = $item.find('> .flavor-pb-repeater-item-body');
                const $icon = $(this).find('.dashicons');

                $body.slideToggle(200);
                $icon.toggleClass('dashicons-arrow-down-alt2 dashicons-arrow-up-alt2');
            });

            // Repeater: add item
            $(document).on('click', '.flavor-pb-add-repeater-item', function(e) {
                e.preventDefault();
                const fieldName = $(this).data('field-name');
                self.addRepeaterItem(fieldName);
            });

            // Repeater: remove item
            $(document).on('click', '.flavor-pb-repeater-remove', function(e) {
                e.preventDefault();
                if (!confirm('¿Eliminar este item?')) return;
                const fieldName = $(this).data('field-name');
                const $item = $(this).closest('.flavor-pb-repeater-item');
                $item.slideUp(200, function() {
                    $(this).remove();
                    const $repeater = $('.flavor-pb-repeater[data-field-name="' + fieldName + '"]');
                    $repeater.find('.flavor-pb-repeater-item').each(function(idx) {
                        $(this).attr('data-index', idx);
                    });
                });
            });

            // Repeater: click on header to toggle
            $(document).on('click', '.flavor-pb-repeater-item-header', function(e) {
                if ($(e.target).closest('.flavor-pb-repeater-item-actions').length) return;
                $(this).find('.flavor-pb-repeater-toggle').trigger('click');
            });

            // Data source: toggle between manual/dynamic
            $(document).on('change', '.flavor-pb-data-source-select', function() {
                const source = $(this).val();
                const $container = $(this).closest('.flavor-pb-data-source-container');
                const itemsField = $container.data('items-field');
                const $filters = $container.find('.flavor-pb-data-source-filters');

                if (source === 'manual') {
                    $filters.slideUp(200);
                } else {
                    $filters.slideDown(200);
                }

                const $repeaterField = $('.flavor-pb-repeater[data-field-name="' + itemsField + '"]').closest('.flavor-pb-field');
                if (source === 'manual') {
                    $repeaterField.slideDown(200);
                } else {
                    $repeaterField.slideUp(200);
                }
            });

            // Guardar edición desde modal (compatibilidad)
            $('#flavor-pb-save-component').on('click', function() {
                self.saveComponentEdit();
            });

            // Guardar desde panel lateral
            $(document).on('click', '#flavor-pb-save-props', function() {
                self.saveComponentFromPanel();
            });

            // Cancelar panel lateral
            $(document).on('click', '#flavor-pb-cancel-props, .flavor-pb-properties-close', function() {
                self.deselectComponent();
            });

            // Tabs del panel de propiedades (Contenido / Diseño)
            $(document).on('click', '.flavor-pb-prop-tab', function() {
                var targetTab = $(this).data('tab');
                $('.flavor-pb-prop-tab').removeClass('active');
                $(this).addClass('active');
                $('.flavor-pb-tab-content').removeClass('active');
                $('.flavor-pb-tab-content[data-tab-content="' + targetTab + '"]').addClass('active');
            });

            // Cancelar edición modal
            $('#flavor-pb-cancel-edit, .flavor-pb-close-modal').on('click', function() {
                $('#flavor-pb-edit-modal').fadeOut();
                $('#flavor-pb-templates-modal').fadeOut();
            });

            // Usar plantilla
            $(document).on('click', '.flavor-pb-use-template', function() {
                const templateId = $(this).closest('.flavor-pb-template-card').data('template-id');
                self.loadTemplate(templateId);
            });

            // Vista previa fullscreen
            $('#flavor-pb-preview').on('click', function() {
                self.openFullscreenPreview();
            });

            // Cerrar fullscreen preview
            $(document).on('click', '.flavor-pb-fullscreen-close', function() {
                self.closeFullscreenPreview();
            });

            // Responsive viewport toggle
            $(document).on('click', '.flavor-pb-responsive-toggle button', function() {
                const device = $(this).data('viewport');
                self.setViewportDevice(device);
                $(this).siblings().removeClass('active');
                $(this).addClass('active');
            });

            // Undo/Redo buttons
            $('#flavor-pb-undo').on('click', function() {
                self.undo();
            });

            $('#flavor-pb-redo').on('click', function() {
                self.redo();
            });

            // Keyboard shortcuts
            $(document).on('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
                    if ($(e.target).closest('#flavor-page-builder').length || e.target === document.body) {
                        e.preventDefault();
                        self.undo();
                    }
                }
                if ((e.ctrlKey || e.metaKey) && (e.key === 'y' || (e.key === 'z' && e.shiftKey))) {
                    if ($(e.target).closest('#flavor-page-builder').length || e.target === document.body) {
                        e.preventDefault();
                        self.redo();
                    }
                }
                // Escape to close panel
                if (e.key === 'Escape') {
                    if (self.selectedComponentIndex !== null) {
                        self.deselectComponent();
                    }
                    self.closeFullscreenPreview();
                }
            });
        },

        initSortable: function() {
            const self = this;

            $('#flavor-pb-components-list').sortable({
                handle: '.flavor-pb-component-header',
                placeholder: 'flavor-pb-sortable-placeholder',
                update: function() {
                    self.updateLayoutOrder();
                    self.pushHistory();
                }
            });
        },

        updateLayoutOrder: function() {
            const self = this;
            const nuevaDisposicion = [];

            $('#flavor-pb-components-list .flavor-pb-component-item').each(function(index) {
                const oldIndex = $(this).data('index');
                nuevaDisposicion.push(self.layout[oldIndex]);
                $(this).data('index', index).attr('data-index', index);
            });

            this.layout = nuevaDisposicion;
            this.saveLayout();
        },

        openComponentLibrary: function() {
            $('#flavor-pb-sidebar').fadeIn();
        },

        addComponent: function(componentId) {
            const component = this.components[componentId];
            if (!component) return;

            const componentData = {
                component_id: componentId,
                data: this.getDefaultFieldValues(component.fields),
                settings: {
                    align: '',
                    spacing: {
                        margin: {top: 0, bottom: 0},
                        padding: {top: 0, bottom: 0}
                    },
                    background: {color: '', image: ''}
                }
            };

            this.layout.push(componentData);
            this.saveLayout();
            this.renderComponent(this.layout.length - 1, componentData);
            this.removeEmptyState();
            this.pushHistory();
        },

        getDefaultFieldValues: function(fields) {
            const valoresPorDefecto = {};
            for (const fieldName in fields) {
                const fieldDefault = fields[fieldName].default;
                if (fieldDefault !== undefined) {
                    if (Array.isArray(fieldDefault)) {
                        valoresPorDefecto[fieldName] = JSON.parse(JSON.stringify(fieldDefault));
                    } else if (typeof fieldDefault === 'object' && fieldDefault !== null) {
                        valoresPorDefecto[fieldName] = JSON.parse(JSON.stringify(fieldDefault));
                    } else {
                        valoresPorDefecto[fieldName] = fieldDefault;
                    }
                } else {
                    valoresPorDefecto[fieldName] = '';
                }
            }
            return valoresPorDefecto;
        },

        renderComponent: function(index, componentData) {
            const component = this.components[componentData.component_id];
            if (!component) return;

            const html = `
                <div class="flavor-pb-component-item" data-index="${index}">
                    <div class="flavor-pb-component-header">
                        <div class="flavor-pb-component-info">
                            <span class="dashicons ${component.icon}"></span>
                            <span class="flavor-pb-component-label">${component.label}</span>
                        </div>
                        <div class="flavor-pb-component-actions">
                            <button type="button" class="flavor-pb-edit-component" title="${flavorPageBuilder.i18n.edit || 'Editar'}">
                                <span class="dashicons dashicons-edit"></span>
                            </button>
                            <button type="button" class="flavor-pb-duplicate-component" title="${flavorPageBuilder.i18n.duplicate || 'Duplicar'}">
                                <span class="dashicons dashicons-admin-page"></span>
                            </button>
                            <button type="button" class="flavor-pb-move-up" title="${flavorPageBuilder.i18n.moveUp || 'Subir'}">
                                <span class="dashicons dashicons-arrow-up-alt2"></span>
                            </button>
                            <button type="button" class="flavor-pb-move-down" title="${flavorPageBuilder.i18n.moveDown || 'Bajar'}">
                                <span class="dashicons dashicons-arrow-down-alt2"></span>
                            </button>
                            <button type="button" class="flavor-pb-delete-component" title="${flavorPageBuilder.i18n.delete || 'Eliminar'}">
                                <span class="dashicons dashicons-trash"></span>
                            </button>
                        </div>
                    </div>
                    <div class="flavor-pb-component-preview">
                        <div class="flavor-pb-preview-loading">
                            <span class="dashicons dashicons-update spin"></span>
                            Cargando preview...
                        </div>
                        <div class="flavor-pb-preview-overlay" title="Click para editar propiedades"></div>
                    </div>
                </div>
            `;

            $('#flavor-pb-components-list').append(html);

            // Observe for lazy loading
            if (this.previewObserver) {
                const addedItem = $('#flavor-pb-components-list .flavor-pb-component-item').last()[0];
                if (addedItem) {
                    this.previewObserver.observe(addedItem);
                }
            }
        },

        removeEmptyState: function() {
            $('.flavor-pb-empty-state').remove();
        },

        // ========================================
        // COMPONENT SELECTION & PROPERTIES PANEL
        // ========================================

        selectComponent: function(index) {
            if (this.selectedComponentIndex === index) return;

            this.deselectComponent();
            this.selectedComponentIndex = index;

            const $item = $('.flavor-pb-component-item[data-index="' + index + '"]');
            $item.addClass('flavor-pb-selected');

            this.buildPropertiesPanel(index);
            $('#flavor-pb-properties-panel').show();
        },

        deselectComponent: function() {
            if (this.selectedComponentIndex === null) return;

            $('.flavor-pb-component-item').removeClass('flavor-pb-selected');
            this.selectedComponentIndex = null;
            $('#flavor-pb-properties-panel').hide();
        },

        buildPropertiesPanel: function(index) {
            const componentData = this.layout[index];
            const component = this.components[componentData.component_id];

            if (!component) return;

            // === Pestaña Contenido ===
            let contentHtml = '<h4 style="margin:0 0 15px;color:#0073aa;">' + this.escapeHtml(component.label) + '</h4>';

            for (const fieldName in component.fields) {
                const field = component.fields[fieldName];
                let value = componentData.data[fieldName];
                if (value === undefined || value === null) {
                    value = field.default !== undefined ? field.default : '';
                }
                contentHtml += this.renderField(fieldName, field, value);
            }

            // === Pestaña Diseño ===
            const settings = componentData.settings || {};
            const spacing = settings.spacing || {};
            const marginValues = spacing.margin || {top: 0, bottom: 0};
            const paddingValues = spacing.padding || {top: 0, bottom: 0};
            const background = settings.background || {color: '', image: ''};
            const customClass = settings.custom_class || '';
            const alignValue = settings.align || '';
            const visibilityDesktop = settings.visibility_desktop !== false;
            const visibilityTablet = settings.visibility_tablet !== false;
            const visibilityMobile = settings.visibility_mobile !== false;

            let designHtml = '';

            // Alineación
            designHtml += '<div class="flavor-pb-design-section">';
            designHtml += '<h4 class="flavor-pb-design-section-title">Alineación</h4>';
            designHtml += '<div class="flavor-pb-align-buttons">';
            designHtml += '<button type="button" class="flavor-pb-align-btn' + (alignValue === 'left' ? ' active' : '') + '" data-align="left" title="Izquierda"><span class="dashicons dashicons-editor-alignleft"></span></button>';
            designHtml += '<button type="button" class="flavor-pb-align-btn' + (alignValue === 'center' ? ' active' : '') + '" data-align="center" title="Centro"><span class="dashicons dashicons-editor-aligncenter"></span></button>';
            designHtml += '<button type="button" class="flavor-pb-align-btn' + (alignValue === 'right' ? ' active' : '') + '" data-align="right" title="Derecha"><span class="dashicons dashicons-editor-alignright"></span></button>';
            designHtml += '<button type="button" class="flavor-pb-align-btn' + (alignValue === '' ? ' active' : '') + '" data-align="" title="Ninguna"><span class="dashicons dashicons-no"></span></button>';
            designHtml += '</div>';
            designHtml += '</div>';

            // Espaciado
            designHtml += '<div class="flavor-pb-design-section">';
            designHtml += '<h4 class="flavor-pb-design-section-title">Espaciado</h4>';
            designHtml += '<div class="flavor-pb-spacing-grid">';
            designHtml += '<div class="flavor-pb-spacing-group">';
            designHtml += '<label>Margen</label>';
            designHtml += '<div class="flavor-pb-spacing-inputs">';
            designHtml += '<div class="flavor-pb-spacing-input"><span>↑</span><input type="number" name="design_margin_top" value="' + parseInt(marginValues.top || 0) + '" min="0" max="200" step="5"></div>';
            designHtml += '<div class="flavor-pb-spacing-input"><span>↓</span><input type="number" name="design_margin_bottom" value="' + parseInt(marginValues.bottom || 0) + '" min="0" max="200" step="5"></div>';
            designHtml += '</div>';
            designHtml += '</div>';
            designHtml += '<div class="flavor-pb-spacing-group">';
            designHtml += '<label>Padding</label>';
            designHtml += '<div class="flavor-pb-spacing-inputs">';
            designHtml += '<div class="flavor-pb-spacing-input"><span>↑</span><input type="number" name="design_padding_top" value="' + parseInt(paddingValues.top || 0) + '" min="0" max="200" step="5"></div>';
            designHtml += '<div class="flavor-pb-spacing-input"><span>↓</span><input type="number" name="design_padding_bottom" value="' + parseInt(paddingValues.bottom || 0) + '" min="0" max="200" step="5"></div>';
            designHtml += '</div>';
            designHtml += '</div>';
            designHtml += '</div>';
            designHtml += '</div>';

            // Fondo
            designHtml += '<div class="flavor-pb-design-section">';
            designHtml += '<h4 class="flavor-pb-design-section-title">Fondo</h4>';
            designHtml += '<div class="flavor-pb-field"><label>Color de fondo</label>';
            designHtml += '<input type="text" name="design_bg_color" value="' + this.escapeHtml(background.color || '') + '" class="flavor-pb-color-picker"></div>';
            designHtml += '<div class="flavor-pb-field"><label>Imagen de fondo</label>';
            designHtml += '<div class="flavor-pb-image-field">';
            designHtml += '<input type="hidden" name="design_bg_image" value="' + this.escapeHtml(background.image || '') + '" class="flavor-pb-image-id">';
            designHtml += '<div class="flavor-pb-image-preview">';
            if (background.image) {
                designHtml += '<span class="dashicons dashicons-format-image flavor-pb-image-loading" data-attachment-id="' + this.escapeHtml(background.image) + '"></span>';
            } else {
                designHtml += '<span class="dashicons dashicons-format-image"></span>';
            }
            designHtml += '</div>';
            designHtml += '<button type="button" class="button flavor-pb-upload-image">Seleccionar imagen</button>';
            designHtml += '<button type="button" class="button flavor-pb-remove-image" ' + (!background.image ? 'style="display:none"' : '') + '>Quitar</button>';
            designHtml += '</div></div>';
            designHtml += '</div>';

            // Visibilidad por dispositivo
            designHtml += '<div class="flavor-pb-design-section">';
            designHtml += '<h4 class="flavor-pb-design-section-title">Visibilidad</h4>';
            designHtml += '<div class="flavor-pb-visibility-toggles">';
            designHtml += '<label class="flavor-pb-visibility-toggle"><input type="checkbox" name="design_vis_desktop" ' + (visibilityDesktop ? 'checked' : '') + '><span class="dashicons dashicons-desktop"></span> Escritorio</label>';
            designHtml += '<label class="flavor-pb-visibility-toggle"><input type="checkbox" name="design_vis_tablet" ' + (visibilityTablet ? 'checked' : '') + '><span class="dashicons dashicons-tablet"></span> Tablet</label>';
            designHtml += '<label class="flavor-pb-visibility-toggle"><input type="checkbox" name="design_vis_mobile" ' + (visibilityMobile ? 'checked' : '') + '><span class="dashicons dashicons-smartphone"></span> Móvil</label>';
            designHtml += '</div>';
            designHtml += '</div>';

            // Clase CSS personalizada
            designHtml += '<div class="flavor-pb-design-section">';
            designHtml += '<h4 class="flavor-pb-design-section-title">Avanzado</h4>';
            designHtml += '<div class="flavor-pb-field"><label>Clase CSS personalizada</label>';
            designHtml += '<input type="text" name="design_custom_class" value="' + this.escapeHtml(customClass) + '" placeholder="mi-clase-custom" style="width:100%;"></div>';
            designHtml += '</div>';

            // Insertar en las pestañas
            $('.flavor-pb-tab-content[data-tab-content="content"]').html(contentHtml);
            $('.flavor-pb-tab-content[data-tab-content="design"]').html(designHtml);

            // Reset a pestaña contenido
            $('.flavor-pb-prop-tab').removeClass('active');
            $('.flavor-pb-prop-tab[data-tab="content"]').addClass('active');
            $('.flavor-pb-tab-content').removeClass('active');
            $('.flavor-pb-tab-content[data-tab-content="content"]').addClass('active');

            // Init color pickers en ambas pestañas
            $('#flavor-pb-properties-body .flavor-pb-color-picker').wpColorPicker();

            // Init media uploader
            this.initMediaUploader('#flavor-pb-properties-body');

            // Resolve image previews
            this.resolveImagePreviews('#flavor-pb-properties-body');

            // Init align buttons
            $(document).off('click.designAlign').on('click.designAlign', '.flavor-pb-align-btn', function() {
                $(this).siblings().removeClass('active');
                $(this).addClass('active');
            });

            // Handle initial data_source visibility
            $('.flavor-pb-tab-content[data-tab-content="content"] .flavor-pb-data-source-select').each(function() {
                const source = $(this).val();
                const $container = $(this).closest('.flavor-pb-data-source-container');
                const itemsField = $container.data('items-field');
                const $filters = $container.find('.flavor-pb-data-source-filters');

                if (source === 'manual') {
                    $filters.hide();
                } else {
                    $filters.show();
                    var $repeaterField = $('.flavor-pb-repeater[data-field-name="' + itemsField + '"]').closest('.flavor-pb-field');
                    $repeaterField.hide();
                }
            });
        },

        saveComponentFromPanel: function() {
            var componentData = this.layout[this.selectedComponentIndex];
            var componentDef = this.components[componentData.component_id];
            var formData = {};
            var $contentTab = $('.flavor-pb-tab-content[data-tab-content="content"]');
            var $designTab = $('.flavor-pb-tab-content[data-tab-content="design"]');

            // === Leer campos de Contenido ===
            for (var fieldName in componentDef.fields) {
                if (!componentDef.fields.hasOwnProperty(fieldName)) continue;
                var fieldDef = componentDef.fields[fieldName];

                if (fieldDef.type === 'repeater') {
                    var repeaterItems = [];
                    var $repeater = $contentTab.find('.flavor-pb-repeater[data-field-name="' + fieldName + '"]');

                    $repeater.find('.flavor-pb-repeater-item').each(function() {
                        var itemData = {};
                        var $body = $(this).find('> .flavor-pb-repeater-item-body');

                        for (var subFieldName in fieldDef.fields) {
                            if (!fieldDef.fields.hasOwnProperty(subFieldName)) continue;
                            var $subInput = $body.find('[name="' + subFieldName + '"]');

                            if ($subInput.length) {
                                if ($subInput.attr('type') === 'checkbox') {
                                    itemData[subFieldName] = $subInput.is(':checked');
                                } else {
                                    itemData[subFieldName] = $subInput.val() || '';
                                }
                            }
                        }
                        repeaterItems.push(itemData);
                    });

                    formData[fieldName] = repeaterItems;

                } else if (fieldDef.type === 'data_source') {
                    var $container = $contentTab.find('.flavor-pb-data-source-container[data-field-name="' + fieldName + '"]');
                    formData[fieldName] = {
                        source: $container.find('.flavor-pb-data-source-select').val() || 'manual',
                        limite: parseInt($container.find('[name="ds_limite"]').val()) || 6,
                        orden: $container.find('[name="ds_orden"]').val() || 'date_desc'
                    };

                } else {
                    var $input = $contentTab.find('[name="' + fieldName + '"]');
                    if ($input.length) {
                        if ($input.attr('type') === 'checkbox') {
                            formData[fieldName] = $input.is(':checked');
                        } else {
                            formData[fieldName] = $input.val();
                        }
                    }
                }
            }

            // === Leer campos de Diseño ===
            var alignActive = $designTab.find('.flavor-pb-align-btn.active').data('align') || '';
            var designSettings = {
                align: alignActive,
                spacing: {
                    margin: {
                        top: parseInt($designTab.find('[name="design_margin_top"]').val()) || 0,
                        bottom: parseInt($designTab.find('[name="design_margin_bottom"]').val()) || 0
                    },
                    padding: {
                        top: parseInt($designTab.find('[name="design_padding_top"]').val()) || 0,
                        bottom: parseInt($designTab.find('[name="design_padding_bottom"]').val()) || 0
                    }
                },
                background: {
                    color: $designTab.find('[name="design_bg_color"]').val() || '',
                    image: $designTab.find('[name="design_bg_image"]').val() || ''
                },
                custom_class: $designTab.find('[name="design_custom_class"]').val() || '',
                visibility_desktop: $designTab.find('[name="design_vis_desktop"]').is(':checked'),
                visibility_tablet: $designTab.find('[name="design_vis_tablet"]').is(':checked'),
                visibility_mobile: $designTab.find('[name="design_vis_mobile"]').is(':checked')
            };

            this.layout[this.selectedComponentIndex].data = formData;
            this.layout[this.selectedComponentIndex].settings = designSettings;
            this.saveLayout();
            this.pushHistory();

            // Refresh preview of this component
            this.refreshComponentPreview(this.selectedComponentIndex);
        },

        // ========================================
        // COMPONENT PREVIEW (iframes + lazy loading)
        // ========================================

        initPreviewObserver: function() {
            var self = this;

            if (!('IntersectionObserver' in window)) {
                // Fallback: load all previews
                this.layout.forEach(function(data, index) {
                    self.loadComponentPreview(index, data);
                });
                return;
            }

            this.previewObserver = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        var $item = $(entry.target);
                        var index = $item.data('index');
                        if (index !== undefined && self.layout[index]) {
                            self.loadComponentPreview(index, self.layout[index]);
                            self.previewObserver.unobserve(entry.target);
                        }
                    }
                });
            }, {
                rootMargin: '200px',
                threshold: 0.01
            });

            // Observe all existing component items
            $('#flavor-pb-components-list .flavor-pb-component-item').each(function() {
                self.previewObserver.observe(this);
            });
        },

        getPreviewCacheKey: function(index, data) {
            return data.component_id + '_' + JSON.stringify(data.data || {}) + '_' + JSON.stringify(data.settings || {});
        },

        loadComponentPreview: function(index, componentData) {
            var self = this;
            var cacheKey = this.getPreviewCacheKey(index, componentData);

            // Check cache
            if (this.previewCache[cacheKey]) {
                this.renderPreviewIframe(index, this.previewCache[cacheKey]);
                return;
            }

            // Throttle concurrent requests
            if (this.activePreviewRequests >= this.maxConcurrentPreviews) {
                setTimeout(function() {
                    self.loadComponentPreview(index, componentData);
                }, 500);
                return;
            }

            this.activePreviewRequests++;

            $.ajax({
                url: flavorPageBuilder.ajaxUrl,
                type: 'POST',
                data: {
                    action: 'flavor_preview_component',
                    nonce: flavorPageBuilder.nonce,
                    component_id: componentData.component_id,
                    component_data: JSON.stringify(componentData.data || {}),
                    component_settings: JSON.stringify(componentData.settings || {}),
                    post_id: flavorPageBuilder.postId || 0
                },
                success: function(response) {
                    if (response.success && response.data.html) {
                        self.previewCache[cacheKey] = response.data.html;
                        self.renderPreviewIframe(index, response.data.html);
                    } else {
                        self.renderPreviewFallback(index, componentData);
                    }
                },
                error: function() {
                    self.renderPreviewFallback(index, componentData);
                },
                complete: function() {
                    self.activePreviewRequests--;
                }
            });
        },

        renderPreviewIframe: function(index, htmlContent) {
            var $item = $('.flavor-pb-component-item[data-index="' + index + '"]');
            if (!$item.length) return;

            var $preview = $item.find('.flavor-pb-component-preview');

            // Build iframe srcdoc with Tailwind for styling isolation
            var srcdoc = '<!DOCTYPE html><html><head>'
                + '<meta charset="utf-8">'
                + '<meta name="viewport" content="width=device-width,initial-scale=1">'
                + '<script src="https://cdn.tailwindcss.com"><\/script>'
                + '<style>body{margin:0;padding:0;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,sans-serif;}</style>'
                + '</head><body>' + htmlContent + '</body></html>';

            var $iframe = $('<iframe class="flavor-pb-preview-iframe" scrolling="no"></iframe>');
            $iframe.attr('srcdoc', srcdoc);

            // Auto-resize iframe on load
            $iframe.on('load', function() {
                try {
                    var iframeBody = this.contentDocument.body;
                    var contentHeight = iframeBody.scrollHeight;
                    $(this).css('height', Math.min(contentHeight, 500) + 'px');
                } catch (e) {
                    $(this).css('height', '200px');
                }
            });

            // Replace loading with iframe
            $preview.find('.flavor-pb-preview-loading').remove();
            $preview.find('.flavor-pb-preview-iframe').remove();
            $preview.prepend($iframe);
        },

        renderPreviewFallback: function(index, componentData) {
            var component = this.components[componentData.component_id];
            if (!component) return;

            var $item = $('.flavor-pb-component-item[data-index="' + index + '"]');
            if (!$item.length) return;

            var $preview = $item.find('.flavor-pb-component-preview');
            $preview.find('.flavor-pb-preview-loading').html(
                '<div class="flavor-pb-component-preview-placeholder">' +
                '<span class="dashicons ' + component.icon + '"></span>' +
                '</div>'
            );
        },

        refreshComponentPreview: function(index) {
            var componentData = this.layout[index];
            if (!componentData) return;

            // Invalidate cache for this component
            var cacheKey = this.getPreviewCacheKey(index, componentData);
            delete this.previewCache[cacheKey];

            // Show loading state
            var $item = $('.flavor-pb-component-item[data-index="' + index + '"]');
            var $preview = $item.find('.flavor-pb-component-preview');
            $preview.find('.flavor-pb-preview-iframe').remove();
            $preview.find('.flavor-pb-preview-loading').remove();
            $preview.prepend('<div class="flavor-pb-preview-loading"><span class="dashicons dashicons-update spin"></span> Actualizando preview...</div>');

            // Reload
            this.loadComponentPreview(index, componentData);
        },

        // ========================================
        // VIEWPORT TOGGLE
        // ========================================

        setViewportDevice: function(device) {
            var $viewport = $('.flavor-pb-canvas-viewport');
            $viewport.removeClass('viewport-desktop viewport-tablet viewport-mobile');
            $viewport.addClass('viewport-' + device);
        },

        // ========================================
        // FULLSCREEN PREVIEW
        // ========================================

        openFullscreenPreview: function() {
            var self = this;

            if (this.layout.length === 0) {
                alert('No hay componentes para previsualizar. Añade algunos primero.');
                return;
            }

            var $btn = $('#flavor-pb-preview');
            var originalText = $btn.html();
            $btn.html('<span class="dashicons dashicons-update spin"></span> Generando...').prop('disabled', true);

            var postId = $('#post_ID').val() || 0;
            var layoutJson = JSON.stringify(this.layout);

            $.ajax({
                url: flavorPageBuilder.ajaxUrl || ajaxurl,
                type: 'POST',
                data: {
                    action: 'flavor_save_preview',
                    nonce: flavorPageBuilder.nonce,
                    layout: layoutJson,
                    post_id: postId
                },
                success: function(response) {
                    if (response.success && response.data.preview_url) {
                        var $overlay = $('#flavor-pb-fullscreen-preview');
                        var $iframe = $('#flavor-pb-fullscreen-iframe');
                        $iframe.attr('src', response.data.preview_url);
                        $overlay.css('display', 'flex');
                    } else {
                        alert('Error al generar vista previa: ' + (response.data.message || 'Error desconocido'));
                    }
                },
                error: function() {
                    alert('Error de conexión al generar vista previa');
                },
                complete: function() {
                    $btn.html(originalText).prop('disabled', false);
                }
            });
        },

        closeFullscreenPreview: function() {
            var $overlay = $('#flavor-pb-fullscreen-preview');
            if ($overlay.is(':visible')) {
                $overlay.hide();
                $('#flavor-pb-fullscreen-iframe').attr('src', 'about:blank');
            }
        },

        // ========================================
        // UNDO / REDO
        // ========================================

        pushHistory: function() {
            var stateJson = JSON.stringify(this.layout);

            // Truncate any future states if we're not at the end
            if (this.historyPointer < this.historyStack.length - 1) {
                this.historyStack = this.historyStack.slice(0, this.historyPointer + 1);
            }

            this.historyStack.push(stateJson);

            // Enforce max size
            if (this.historyStack.length > this.maxHistorySize) {
                this.historyStack.shift();
            }

            this.historyPointer = this.historyStack.length - 1;
            this.updateUndoRedoButtons();
        },

        undo: function() {
            if (this.historyPointer <= 0) return;

            this.historyPointer--;
            var stateJson = this.historyStack[this.historyPointer];
            this.layout = JSON.parse(stateJson);
            this.saveLayout();
            this.deselectComponent();
            this.refreshCanvas();
            this.updateUndoRedoButtons();
        },

        redo: function() {
            if (this.historyPointer >= this.historyStack.length - 1) return;

            this.historyPointer++;
            var stateJson = this.historyStack[this.historyPointer];
            this.layout = JSON.parse(stateJson);
            this.saveLayout();
            this.deselectComponent();
            this.refreshCanvas();
            this.updateUndoRedoButtons();
        },

        updateUndoRedoButtons: function() {
            $('#flavor-pb-undo').prop('disabled', this.historyPointer <= 0);
            $('#flavor-pb-redo').prop('disabled', this.historyPointer >= this.historyStack.length - 1);
        },

        // ========================================
        // EXISTING METHODS (adapted)
        // ========================================

        editComponent: function(index) {
            // Redirect to selectComponent (panel lateral)
            this.selectComponent(index);
        },

        renderField: function(name, field, value) {
            let html = '<div class="flavor-pb-field">';
            html += '<label class="flavor-pb-field-label">' + (field.label || name) + '</label>';

            switch (field.type) {
                case 'text':
                    html += '<input type="text" name="' + name + '" value="' + this.escapeHtml(value) + '" class="widefat">';
                    break;

                case 'textarea':
                    html += '<textarea name="' + name + '" rows="4" class="widefat">' + this.escapeHtml(value) + '</textarea>';
                    break;

                case 'number':
                    html += '<input type="number" name="' + name + '" value="' + value + '" class="widefat">';
                    break;

                case 'url':
                    html += '<input type="url" name="' + name + '" value="' + this.escapeHtml(value) + '" class="widefat">';
                    break;

                case 'toggle':
                case 'checkbox':
                    html += '<label class="flavor-pb-toggle">';
                    html += '<input type="checkbox" name="' + name + '" value="1" ' + (value ? 'checked' : '') + '>';
                    html += '<span class="flavor-pb-toggle-slider"></span>';
                    html += '</label>';
                    break;

                case 'select':
                    html += '<select name="' + name + '" class="widefat">';
                    for (const option of field.options) {
                        html += '<option value="' + option + '" ' + (value == option ? 'selected' : '') + '>' + option + '</option>';
                    }
                    html += '</select>';
                    break;

                case 'color':
                    html += '<input type="text" name="' + name + '" value="' + value + '" class="flavor-pb-color-picker">';
                    break;

                case 'image':
                    var hasImage = !!value;
                    var isNumericId = hasImage && !isNaN(value) && String(parseInt(value)) === String(value);
                    html += '<div class="flavor-pb-image-field">';
                    html += '<input type="hidden" name="' + name + '" value="' + value + '" class="flavor-pb-image-id">';
                    html += '<div class="flavor-pb-image-preview">';
                    if (hasImage && !isNumericId) {
                        html += '<img src="' + value + '" alt="">';
                    } else if (hasImage && isNumericId) {
                        html += '<span class="dashicons dashicons-format-image flavor-pb-image-loading" data-attachment-id="' + value + '"></span>';
                    } else {
                        html += '<span class="dashicons dashicons-format-image"></span>';
                    }
                    html += '</div>';
                    html += '<button type="button" class="button flavor-pb-upload-image">Seleccionar Imagen</button>';
                    html += '<button type="button" class="button flavor-pb-remove-image" ' + (!hasImage ? 'style="display:none"' : '') + '>Eliminar</button>';
                    html += '</div>';
                    break;

                case 'repeater':
                    var repeaterItems = Array.isArray(value) ? value : [];
                    html += '<div class="flavor-pb-repeater" data-field-name="' + name + '" data-max-items="' + (field.max_items || 10) + '">';
                    html += '<div class="flavor-pb-repeater-items">';
                    for (var repeaterIdx = 0; repeaterIdx < repeaterItems.length; repeaterIdx++) {
                        html += this.renderRepeaterItem(name, field.fields, repeaterItems[repeaterIdx], repeaterIdx);
                    }
                    html += '</div>';
                    html += '<button type="button" class="button flavor-pb-add-repeater-item" data-field-name="' + name + '">';
                    html += '<span class="dashicons dashicons-plus-alt2"></span> Añadir item';
                    html += '</button>';
                    html += '</div>';
                    break;

                case 'data_source':
                    var sourceConfig = (typeof value === 'object' && value !== null) ? value : { source: value || field.default || 'manual' };
                    var currentSource = sourceConfig.source || 'manual';
                    var currentLimite = sourceConfig.limite || 6;
                    var currentOrden = sourceConfig.orden || 'date_desc';
                    var postTypeLabels = {
                        'post': 'Posts del blog',
                        'page': 'Páginas',
                        'product': 'Productos (WooCommerce)',
                        'flavor_evento': 'Eventos'
                    };

                    html += '<div class="flavor-pb-data-source-container" data-field-name="' + name + '" data-items-field="' + (field.items_field || 'items') + '">';
                    html += '<select name="' + name + '" class="widefat flavor-pb-data-source-select">';
                    html += '<option value="manual" ' + (currentSource === 'manual' ? 'selected' : '') + '>Items manuales</option>';
                    if (field.post_types && field.post_types.length > 0) {
                        for (var dsIdx = 0; dsIdx < field.post_types.length; dsIdx++) {
                            var postType = field.post_types[dsIdx];
                            var postTypeLabel = postTypeLabels[postType] || postType;
                            html += '<option value="' + postType + '" ' + (currentSource === postType ? 'selected' : '') + '>' + postTypeLabel + '</option>';
                        }
                    }
                    html += '</select>';

                    html += '<div class="flavor-pb-data-source-filters" style="' + (currentSource === 'manual' ? 'display:none;' : '') + 'margin-top:12px;">';
                    html += '<div class="flavor-pb-field">';
                    html += '<label class="flavor-pb-field-label">Límite de resultados</label>';
                    html += '<input type="number" name="ds_limite" value="' + currentLimite + '" class="widefat" min="1" max="20">';
                    html += '</div>';
                    html += '<div class="flavor-pb-field">';
                    html += '<label class="flavor-pb-field-label">Orden</label>';
                    html += '<select name="ds_orden" class="widefat">';
                    html += '<option value="date_desc" ' + (currentOrden === 'date_desc' ? 'selected' : '') + '>Más recientes</option>';
                    html += '<option value="date_asc" ' + (currentOrden === 'date_asc' ? 'selected' : '') + '>Más antiguos</option>';
                    html += '<option value="title_asc" ' + (currentOrden === 'title_asc' ? 'selected' : '') + '>Título A-Z</option>';
                    html += '<option value="title_desc" ' + (currentOrden === 'title_desc' ? 'selected' : '') + '>Título Z-A</option>';
                    html += '</select>';
                    html += '</div>';
                    html += '</div>';
                    html += '</div>';
                    break;
            }

            html += '</div>';
            return html;
        },

        renderRepeaterItem: function(fieldName, subFields, itemData, index) {
            var firstFieldKey = Object.keys(subFields)[0];
            var itemTitle = (itemData && itemData[firstFieldKey])
                ? this.escapeHtml(String(itemData[firstFieldKey]))
                : 'Item ' + (index + 1);

            var html = '<div class="flavor-pb-repeater-item" data-index="' + index + '">';
            html += '<div class="flavor-pb-repeater-item-header">';
            html += '<span class="dashicons dashicons-menu flavor-pb-repeater-drag"></span>';
            html += '<span class="flavor-pb-repeater-item-title">' + itemTitle + '</span>';
            html += '<div class="flavor-pb-repeater-item-actions">';
            html += '<button type="button" class="flavor-pb-repeater-toggle" title="Expandir/Colapsar">';
            html += '<span class="dashicons dashicons-arrow-down-alt2"></span>';
            html += '</button>';
            html += '<button type="button" class="flavor-pb-repeater-remove" data-field-name="' + fieldName + '" title="Eliminar">';
            html += '<span class="dashicons dashicons-trash"></span>';
            html += '</button>';
            html += '</div>';
            html += '</div>';

            html += '<div class="flavor-pb-repeater-item-body" style="display:none;">';
            for (var subFieldName in subFields) {
                if (!subFields.hasOwnProperty(subFieldName)) continue;
                var subField = subFields[subFieldName];
                var subValue = (itemData && itemData[subFieldName] !== undefined)
                    ? itemData[subFieldName]
                    : (subField.default !== undefined ? subField.default : '');
                html += this.renderField(subFieldName, subField, subValue);
            }
            html += '</div>';
            html += '</div>';

            return html;
        },

        addRepeaterItem: function(fieldName) {
            var editIndex = this.selectedComponentIndex !== null ? this.selectedComponentIndex : this.currentEditingIndex;
            var componentData = this.layout[editIndex];
            var component = this.components[componentData.component_id];
            var fieldDef = component.fields[fieldName];

            if (!fieldDef || fieldDef.type !== 'repeater') return;

            var $repeater = $('.flavor-pb-repeater[data-field-name="' + fieldName + '"]');
            var maxItems = parseInt($repeater.data('max-items')) || 10;
            var currentCount = $repeater.find('.flavor-pb-repeater-item').length;

            if (currentCount >= maxItems) {
                alert('Máximo ' + maxItems + ' items permitidos');
                return;
            }

            var nuevoItemData = {};
            for (var subName in fieldDef.fields) {
                if (!fieldDef.fields.hasOwnProperty(subName)) continue;
                nuevoItemData[subName] = fieldDef.fields[subName].default !== undefined
                    ? fieldDef.fields[subName].default
                    : '';
            }

            var itemHtml = this.renderRepeaterItem(fieldName, fieldDef.fields, nuevoItemData, currentCount);
            $repeater.find('.flavor-pb-repeater-items').append(itemHtml);

            var $nuevoItem = $repeater.find('.flavor-pb-repeater-item').last();
            $nuevoItem.find('> .flavor-pb-repeater-item-body').slideDown(200);
            $nuevoItem.find('.flavor-pb-repeater-toggle .dashicons')
                .removeClass('dashicons-arrow-down-alt2')
                .addClass('dashicons-arrow-up-alt2');
        },

        initMediaUploader: function(containerSelector) {
            var $container = $(containerSelector || '#flavor-pb-edit-modal-body');

            $container.off('click.flavorMedia', '.flavor-pb-upload-image');
            $container.on('click.flavorMedia', '.flavor-pb-upload-image', function(e) {
                e.preventDefault();

                var button = $(this);
                var field = button.closest('.flavor-pb-image-field');

                var frame = wp.media({
                    title: 'Seleccionar Imagen',
                    button: {text: 'Usar esta imagen'},
                    multiple: false
                });

                frame.on('select', function() {
                    var attachment = frame.state().get('selection').first().toJSON();
                    field.find('.flavor-pb-image-id').val(attachment.id);
                    field.find('.flavor-pb-image-preview').html('<img src="' + attachment.url + '" alt="">');
                    field.find('.flavor-pb-remove-image').show();
                });

                frame.open();
            });

            $container.off('click.flavorMedia', '.flavor-pb-remove-image');
            $container.on('click.flavorMedia', '.flavor-pb-remove-image', function(e) {
                e.preventDefault();
                var field = $(this).closest('.flavor-pb-image-field');
                field.find('.flavor-pb-image-id').val('');
                field.find('.flavor-pb-image-preview').html('<span class="dashicons dashicons-format-image"></span>');
                $(this).hide();
            });
        },

        resolveImagePreviews: function(containerSelector) {
            $(containerSelector || '#flavor-pb-edit-modal-body').find('.flavor-pb-image-loading').each(function() {
                var $placeholder = $(this);
                var attachmentId = parseInt($placeholder.data('attachment-id'));

                if (!attachmentId || !wp.media || !wp.media.attachment) return;

                var attachment = wp.media.attachment(attachmentId);
                attachment.fetch().then(function() {
                    var thumbnailUrl = attachment.get('url');
                    if (attachment.get('sizes') && attachment.get('sizes').medium) {
                        thumbnailUrl = attachment.get('sizes').medium.url;
                    } else if (attachment.get('sizes') && attachment.get('sizes').thumbnail) {
                        thumbnailUrl = attachment.get('sizes').thumbnail.url;
                    }
                    if (thumbnailUrl) {
                        $placeholder.replaceWith('<img src="' + thumbnailUrl + '" alt="">');
                    }
                });
            });
        },

        saveComponentEdit: function() {
            var componentData = this.layout[this.currentEditingIndex];
            var componentDef = this.components[componentData.component_id];
            var formData = {};
            var $modalBody = $('#flavor-pb-edit-modal-body');

            for (var fieldName in componentDef.fields) {
                if (!componentDef.fields.hasOwnProperty(fieldName)) continue;
                var fieldDef = componentDef.fields[fieldName];

                if (fieldDef.type === 'repeater') {
                    var repeaterItems = [];
                    var $repeater = $modalBody.find('.flavor-pb-repeater[data-field-name="' + fieldName + '"]');

                    $repeater.find('.flavor-pb-repeater-item').each(function() {
                        var itemData = {};
                        var $body = $(this).find('> .flavor-pb-repeater-item-body');

                        for (var subFieldName in fieldDef.fields) {
                            if (!fieldDef.fields.hasOwnProperty(subFieldName)) continue;
                            var $subInput = $body.find('[name="' + subFieldName + '"]');

                            if ($subInput.length) {
                                if ($subInput.attr('type') === 'checkbox') {
                                    itemData[subFieldName] = $subInput.is(':checked');
                                } else {
                                    itemData[subFieldName] = $subInput.val() || '';
                                }
                            }
                        }
                        repeaterItems.push(itemData);
                    });

                    formData[fieldName] = repeaterItems;

                } else if (fieldDef.type === 'data_source') {
                    var $container = $modalBody.find('.flavor-pb-data-source-container[data-field-name="' + fieldName + '"]');
                    formData[fieldName] = {
                        source: $container.find('.flavor-pb-data-source-select').val() || 'manual',
                        limite: parseInt($container.find('[name="ds_limite"]').val()) || 6,
                        orden: $container.find('[name="ds_orden"]').val() || 'date_desc'
                    };

                } else {
                    var $input = $modalBody.find('[name="' + fieldName + '"]');
                    if ($input.length) {
                        if ($input.attr('type') === 'checkbox') {
                            formData[fieldName] = $input.is(':checked');
                        } else {
                            formData[fieldName] = $input.val();
                        }
                    }
                }
            }

            this.layout[this.currentEditingIndex].data = formData;
            this.saveLayout();
            this.pushHistory();
            $('#flavor-pb-edit-modal').fadeOut();

            // Refresh preview
            this.refreshComponentPreview(this.currentEditingIndex);
        },

        duplicateComponent: function(index) {
            var componentData = JSON.parse(JSON.stringify(this.layout[index]));
            this.layout.splice(index + 1, 0, componentData);
            this.saveLayout();
            this.refreshCanvas();
            this.pushHistory();
        },

        deleteComponent: function(index) {
            if (this.selectedComponentIndex === index) {
                this.deselectComponent();
            }
            this.layout.splice(index, 1);
            this.saveLayout();
            this.refreshCanvas();
            this.pushHistory();
        },

        moveComponent: function(index, direction) {
            if (direction === 'up' && index > 0) {
                var temp = this.layout[index];
                this.layout[index] = this.layout[index - 1];
                this.layout[index - 1] = temp;
            } else if (direction === 'down' && index < this.layout.length - 1) {
                var temp2 = this.layout[index];
                this.layout[index] = this.layout[index + 1];
                this.layout[index + 1] = temp2;
            }
            this.saveLayout();
            this.refreshCanvas();
            this.pushHistory();
        },

        refreshCanvas: function() {
            var self = this;
            $('#flavor-pb-components-list').empty();

            if (this.layout.length === 0) {
                $('#flavor-pb-components-list').html(
                    '<div class="flavor-pb-empty-state">' +
                    '<span class="dashicons dashicons-admin-page"></span>' +
                    '<p>Comienza añadiendo componentes a tu página</p>' +
                    '</div>'
                );
                return;
            }

            for (var i = 0; i < this.layout.length; i++) {
                this.renderComponent(i, this.layout[i]);
            }

            // Re-observe all items for lazy loading
            if (this.previewObserver) {
                $('#flavor-pb-components-list .flavor-pb-component-item').each(function() {
                    self.previewObserver.observe(this);
                });
            }
        },

        escapeHtml: function(text) {
            if (typeof text !== 'string') return String(text != null ? text : '');
            var map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, function(m) { return map[m]; });
        },

        openTemplateLibrary: function() {
            $('#flavor-pb-templates-modal').fadeIn();
        },

        loadTemplate: function(templateId) {
            var template = null;
            var templates = flavorPageBuilder.templates || {};

            for (var sector in templates) {
                if (templates[sector].templates && templates[sector].templates[templateId]) {
                    template = templates[sector].templates[templateId];
                    break;
                }
            }

            if (!template || !template.layout) {
                alert('Template no encontrado');
                return;
            }

            if (this.layout.length > 0) {
                if (!confirm(flavorPageBuilder.i18n.confirmLoadTemplate)) {
                    return;
                }
            }

            this.layout = JSON.parse(JSON.stringify(template.layout));
            this.saveLayout();
            this.refreshCanvas();
            this.pushHistory();
            $('#flavor-pb-templates-modal').fadeOut();

            alert('Plantilla cargada correctamente. ¡Ahora puedes personalizarla!');
        },

        loadLayoutFromData: function(layoutData) {
            if (!layoutData || !Array.isArray(layoutData)) {
                console.error('Layout data inválido');
                return false;
            }

            if (this.layout.length > 0) {
                if (!confirm(flavorPageBuilder.i18n.confirmLoadTemplate || '¿Deseas reemplazar el contenido actual?')) {
                    return false;
                }
            }

            this.layout = JSON.parse(JSON.stringify(layoutData));
            this.saveLayout();
            this.refreshCanvas();
            this.pushHistory();

            return true;
        },

        openPreview: function() {
            this.openFullscreenPreview();
        }
    };

    // Inicializar cuando el documento esté listo
    $(document).ready(function() {
        FlavorPageBuilder.init();
    });

    // Exponer globalmente para integración con otros módulos (ej: AI Assistant)
    window.FlavorPageBuilder = FlavorPageBuilder;

})(jQuery);
