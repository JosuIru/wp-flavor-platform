{
    "version": "2.0.0",
    "categories": {
        "file": {
            "label": "Archivo",
            "shortcuts": {
                "ctrl+s": "save",
                "ctrl+shift+s": "saveAs",
                "ctrl+p": "preview",
                "ctrl+e": "export",
                "ctrl+t": "templates"
            }
        },
        "edit": {
            "label": "Edición",
            "shortcuts": {
                "ctrl+z": "undo",
                "ctrl+shift+z": "redo",
                "ctrl+y": "redo",
                "ctrl+c": "copy",
                "ctrl+x": "cut",
                "ctrl+v": "paste",
                "ctrl+d": "duplicate",
                "ctrl+shift+c": "copyStyles",
                "ctrl+shift+v": "pasteStyles",
                "ctrl+shift+r": "resetStyles"
            }
        },
        "group": {
            "label": "Agrupar",
            "shortcuts": {
                "ctrl+g": "group",
                "ctrl+shift+u": "ungroup"
            }
        },
        "selection": {
            "label": "Selección",
            "shortcuts": {
                "delete": "delete",
                "backspace": "delete",
                "escape": "deselect",
                "ctrl+a": "selectAll",
                "ctrl+shift+a": "invertSelection",
                "ctrl+alt+a": "selectSimilar",
                "enter": "editInline",
                "f2": "editInline",
                "tab": "selectNext",
                "shift+tab": "selectPrevious"
            }
        },
        "navigation": {
            "label": "Navegación",
            "shortcuts": {
                "arrowup": "nudgeUp",
                "arrowdown": "nudgeDown",
                "arrowleft": "nudgeLeft",
                "arrowright": "nudgeRight",
                "shift+arrowup": "nudgeUpLarge",
                "shift+arrowdown": "nudgeDownLarge",
                "shift+arrowleft": "nudgeLeftLarge",
                "shift+arrowright": "nudgeRightLarge",
                "ctrl+arrowup": "moveToTop",
                "ctrl+arrowdown": "moveToBottom",
                "alt+arrowup": "selectParent",
                "alt+arrowdown": "selectFirstChild",
                "alt+enter": "centerInViewport"
            }
        },
