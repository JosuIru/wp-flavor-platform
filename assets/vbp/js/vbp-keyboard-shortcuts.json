            "label": "Colapsar",
            "shortcuts": {
                "ctrl+.": "toggleCollapse"
            }
        },
        "spacing": {
            "label": "Espaciado",
            "shortcuts": {
                "alt+1": "setSpacing8",
                "alt+2": "setSpacing16",
                "alt+3": "setSpacing24",
                "alt+4": "setSpacing32"
            }
        },
        "transform": {
            "label": "Transformación",
            "shortcuts": {
                "alt+shift+h": "flipHorizontal",
                "alt+shift+v": "flipVertical",
                "ctrl+shift+0": "resetPosition",
                "r": "rotate15",
                "shift+r": "rotateNeg15",
                "ctrl+r": "rotate90",
                "ctrl+alt+0": "resetRotation"
            }
        },
        "bookmarks": {
            "label": "Marcadores",
            "shortcuts": {
                "ctrl+shift+1": "goToBookmark1",
                "ctrl+shift+2": "goToBookmark2",
                "ctrl+shift+3": "goToBookmark3",
