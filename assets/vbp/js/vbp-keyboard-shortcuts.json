            "label": "Restricciones",
            "shortcuts": {
                "ctrl+alt+t": "toggleConstraintTop",
                "ctrl+alt+b": "toggleConstraintBottom",
                "ctrl+alt+l": "toggleConstraintLeft",
                "ctrl+alt+right": "toggleConstraintRight"
            }
        },
        "breakpoints": {
            "label": "Breakpoints",
            "shortcuts": {
                "1": "breakpointDesktop",
                "2": "breakpointTablet",
                "3": "breakpointMobile"
            }
        },
