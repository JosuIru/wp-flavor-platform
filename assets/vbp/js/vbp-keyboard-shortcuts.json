            "label": "Portapapeles",
            "shortcuts": {
                "ctrl+alt+shift+h": "copyAsHTML",
                "ctrl+alt+shift+j": "copyAsJSON",
                "ctrl+alt+shift+v": "pasteFromJSON"
            }
        },
        "find": {
            "label": "Buscar",
            "shortcuts": {
                "ctrl+f": "find",
                "ctrl+shift+f": "findReplace"
            }
        },
        "arrange": {
            "label": "Organizar",
            "shortcuts": {
                "ctrl+alt+shift+a": "stackHorizontal",
                "ctrl+alt+shift+d": "stackVertical",
                "ctrl+alt+shift+e": "swapElements"
            }
