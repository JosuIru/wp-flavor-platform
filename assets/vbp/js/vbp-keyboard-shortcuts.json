            "label": "Plantillas",
            "shortcuts": {
                "ctrl+shift+k": "openTemplatesLibrary",
                "ctrl+alt+shift+c": "saveAsComponent",
                "ctrl+shift+i": "openComponentsLibrary",
                "ctrl+alt+shift+t": "openDesignTokens",
                "ctrl+alt+e": "openExportOptions",
                "ctrl+alt+shift+f": "openFigmaImporter"
            }
        },
