            "label": "Auto-Layout",
            "shortcuts": {
                "shift+a": "toggleAutoLayout",
                "ctrl+shift+arrowup": "decreaseGap",
                "ctrl+shift+arrowdown": "increaseGap"
            }
        },
        "zoom": {
            "label": "Zoom",
            "shortcuts": {
                "ctrl++": "zoomIn",
                "ctrl+=": "zoomIn",
                "ctrl+-": "zoomOut",
                "ctrl+0": "zoomReset",
                "ctrl+1": "zoom100",
                "ctrl+2": "zoom200",
                "ctrl+5": "zoom50"
            }
        },
        "panels": {
            "label": "Paneles",
            "shortcuts": {
                "ctrl+\\": "togglePanels",
                "ctrl+b": "toggleBlocksPanel",
                "ctrl+i": "toggleInspectorPanel",
                "ctrl+l": "toggleLayersPanel"
            }
        },
        "modals": {
            "label": "Modales",
            "shortcuts": {
                "ctrl+k": "commandPalette",
                "?": "help",
                "f1": "help",
                "ctrl+,": "settings"
            }
        },
        "alignment": {
            "label": "Alineación",
            "shortcuts": {
                "alt+a": "alignLeft",
                "alt+d": "alignRight",
                "alt+w": "alignTop",
                "alt+s": "alignBottom",
                "alt+h": "alignCenterH",
                "alt+v": "alignCenterV",
                "alt+shift+a": "alignLeftEdge",
                "alt+shift+d": "alignRightEdge",
                "alt+shift+w": "alignTopEdge",
                "alt+shift+s": "alignBottomEdge",
                "ctrl+alt+h": "distributeH",
                "ctrl+alt+v": "distributeV",
                "ctrl+alt+s": "distributeSpacingH",
                "ctrl+alt+w": "distributeSpacingV"
            }
        },
        "zOrder": {
            "label": "Orden Z",
            "shortcuts": {
                "ctrl+]": "bringForward",
                "ctrl+[": "sendBackward",
                "ctrl+shift+]": "bringToFront",
                "ctrl+shift+[": "sendToBack"
            }
        },
        "size": {
            "label": "Tamaño",
            "shortcuts": {
                "ctrl+alt+m": "matchSize",
                "ctrl+alt+f": "fitContent",
                "ctrl+alt+shift+f": "fillParent",
                "ctrl+shift+w": "wrapInContainer"
            }
        },
        "visibility": {
            "label": "Visibilidad",
            "shortcuts": {
                "ctrl+h": "toggleVisibility",
                "ctrl+shift+h": "hideOthers",
                "ctrl+alt+l": "toggleLock"
            }
