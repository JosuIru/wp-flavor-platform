# Configuración de firma para APKs de Release
# ============================================
#
# INSTRUCCIONES:
# 1. Copia este archivo a "key.properties" (sin .example)
# 2. Genera un keystore con: ../scripts/generate-keystore.sh
# 3. Rellena los valores con tus contraseñas
#
# IMPORTANTE:
# - NO commits key.properties al repositorio
# - Guarda el keystore y contraseñas en lugar seguro
# - Si pierdes el keystore, no podrás publicar actualizaciones

# Contraseña del keystore
storePassword=TU_CONTRASEÑA_STORE

# Contraseña de la clave
keyPassword=TU_CONTRASEÑA_KEY

# Alias de la clave (debe coincidir con el usado al crear el keystore)
keyAlias=flavor-release-key

# Ruta al archivo keystore (relativa al directorio android/)
storeFile=../../keystores/flavor-release.jks
