# Fastlane Appfile
# App identifiers and credentials configuration

# iOS Configuration
app_identifier("com.flavor.app")
apple_id(ENV["APPLE_ID"] || "developer@example.com")
itc_team_id(ENV["ITC_TEAM_ID"])
team_id(ENV["TEAM_ID"])

# Android Configuration
json_key_file(ENV["GOOGLE_PLAY_JSON_KEY"] || "fastlane/play-store-credentials.json")
package_name("com.flavor.app")

