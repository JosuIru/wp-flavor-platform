#!/bin/bash
#
# pre-commit-modules - Hook para validar módulos antes de commit
#
# Instalación:
#   cp tools/hooks/pre-commit-modules .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Este hook verifica que:
#   1. Los módulos en app_config.dart tienen template Flutter
#   2. No se están añadiendo módulos sin soporte
#

set -e

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Rutas
MOBILE_PATH="mobile-apps"
APP_CONFIG="$MOBILE_PATH/lib/core/config/app_config.dart"
FLUTTER_MODULES="$MOBILE_PATH/lib/features/modules"

echo ""
echo "🔍 Validando módulos de app_config.dart..."
echo ""

# Verificar si app_config.dart fue modificado
if ! git diff --cached --name-only | grep -q "app_config.dart"; then
    echo -e "${GREEN}✓ app_config.dart no modificado, saltando validación${NC}"
    exit 0
fi

# Verificar que existen los directorios
if [ ! -f "$APP_CONFIG" ]; then
    echo -e "${YELLOW}⚠ app_config.dart no encontrado, saltando validación${NC}"
    exit 0
fi

if [ ! -d "$FLUTTER_MODULES" ]; then
    echo -e "${YELLOW}⚠ Directorio de módulos Flutter no encontrado${NC}"
    exit 0
fi

# Extraer módulos habilitados del archivo staged
STAGED_CONFIG=$(git show :$APP_CONFIG 2>/dev/null || cat "$APP_CONFIG")

# Extraer IDs de módulos
ENABLED_MODULES=$(echo "$STAGED_CONFIG" | grep -A 50 "enabledModules = \[" | grep "'" | sed "s/.*'\([^']*\)'.*/\1/" | head -20)

ERRORS=0
WARNINGS=0

echo "Módulos habilitados en app_config.dart:"
echo ""

for module in $ENABLED_MODULES; do
    # Convertir ID a nombre de carpeta Flutter (guiones a guiones bajos)
    flutter_folder=$(echo "$module" | tr '-' '_')

    # Verificar si existe el directorio
    if [ ! -d "$FLUTTER_MODULES/$flutter_folder" ]; then
        echo -e "  ${RED}✗ $module${NC} - No existe template Flutter ($flutter_folder/)"
        ERRORS=$((ERRORS + 1))
        continue
    fi

    # Verificar si tiene screen
    if ls "$FLUTTER_MODULES/$flutter_folder/"*_screen.dart 1> /dev/null 2>&1; then
        echo -e "  ${GREEN}✓ $module${NC}"
    else
        echo -e "  ${YELLOW}⚠ $module${NC} - Template existe pero sin *_screen.dart"
        WARNINGS=$((WARNINGS + 1))
    fi
done

echo ""

# Resultado
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}COMMIT BLOQUEADO: $ERRORS módulo(s) sin template Flutter${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Opciones:"
    echo "  1. Eliminar los módulos sin soporte de enabledModules"
    echo "  2. Crear los templates Flutter faltantes"
    echo "  3. Usar --no-verify para saltar esta validación (no recomendado)"
    echo ""
    exit 1
fi

if [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠ $WARNINGS módulo(s) con soporte parcial${NC}"
    echo "  Estos módulos usarán WebView fallback en la app"
    echo ""
fi

echo -e "${GREEN}✓ Validación de módulos completada${NC}"
echo ""

exit 0
